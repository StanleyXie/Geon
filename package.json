{
  "name": "geon-agent",
  "version": "0.1.5",
  "description": "GEON — multi-provider ACP agent for Claude and Gemini with L1/L2/L3 context pipeline",
  "type": "module",
  "bin": {
    "geon": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun --minify && chmod +x dist/index.js",
    "build:lib": "bun build src/lib.ts --outfile dist/lib.js --target bun",
    "dev": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.14.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.0.0",
    "glob": "^11.0.0",
    "gpt-tokenizer": "^2.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
